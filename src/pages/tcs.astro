---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const film = {
  title: 'The Christmas Spirit',
  year: 2022,
  runtime: '85 min',
  genres: ['Comedy', 'Thriller', 'Horror'],
  director: 'Bennet De Brabandere',
  tagline: 'A lone man with the Christmas Spirit trapped in his head must kidnap a teenage girl in order to save Christmas.',
  starringLine: 'Zion Forrest Lee & Nicolas Grimes',
  filmmakers: [
    { name: 'Bennet De Brabandere', role: 'Writer / Director / Editor' },
    { name: 'Stephen Fromstein', role: 'Producer' },
    { name: 'Michael Flax', role: 'Executive Producer' },
  ],
  cast: [
    { name: 'Zion Forrest Lee', role: 'Cole Martin', note: 'Ankle Biters, Salvation' },
    { name: 'Nicolas Grimes', role: 'The Christmas Spirit', note: '' },
    { name: 'Matia Jackett', role: 'Maggie Troy', note: '' },
    { name: 'Alexander Nunez', role: 'Nick', note: '' },
    { name: 'Jordan Kronis', role: 'Young Cole', note: '' },
    { name: 'Christian Potenza', role: 'Officer Ray', note: 'Total Drama, 6teen' },
    { name: 'Samantha Espie', role: "Cole's Mom", note: '' },
    { name: 'Kerry-Lee Finkle', role: 'Shotgun Woman', note: '' },
    { name: 'Chris Handfield', role: 'Officer Theo', note: '' },
    { name: 'Brad Austin', role: "Maggie's Dad", note: '' },
    { name: 'Eman Ayaz', role: 'Gina', note: '' },
    { name: 'Adam Waxman', role: 'Man in Suit', note: '' },
    { name: 'Tavaree Daniel-Simms', role: 'Buddha', note: '' },
    { name: 'Jacklyn Francis', role: "Maggie's Mom", note: '' },
  ],
  logline: 'Years ago, a tragedy on Christmas Eve trapped the Spirit of Christmas in young Cole Martin\'s mind. Now an adult, Cole is haunted by guilt and the spirit\'s insistent plans.',
  synopsis: `Years ago, a tragedy on Christmas Eve trapped the Spirit of Christmas in young Cole Martin's mind. Now an adult, Cole is haunted by guilt and the spirit's insistent plans. When a teenage girl resembling his lost sister posts about her holiday blues, the spirit sees a perfect opportunity for redemption. As Cole stumbles through a wild comedy-thriller, he must navigate his sanity, the ancient spirit's schemes, and the whims of a capricious teenager.`,
  poster: `${base}/images/tcs-poster.jpg`,
  heroBg: `${base}/images/tcs-hero-bg.jpg`,
  stills: [
    { src: `${base}/images/stills-tcs/still-01.jpg`, alt: 'Cole in the workshop with Christmas lights' },
    { src: `${base}/images/stills-tcs/still-02.jpg`, alt: 'Production still' },
    { src: `${base}/images/stills-tcs/still-03.jpg`, alt: 'Production still' },
    { src: `${base}/images/stills-tcs/still-04.jpg`, alt: 'Maggie wrapped in Christmas lights' },
    { src: `${base}/images/stills-tcs/still-05.jpg`, alt: 'Production still' },
    { src: `${base}/images/stills-tcs/still-06.jpg`, alt: 'Production still' },
  ],
  trailer: 'https://player.vimeo.com/video/1025758181',
  pressQuotes: [
    { text: '"Probably the best Christmas horror comedy since Rare Exports. A truly original work."', source: 'Letterboxd', author: 'DrPoop1988' },
    { text: '"The anti-Christmas story" with "over-the-top violent situations."', source: 'Film Threat', author: 'Alan Ng' },
    { text: '"Doesn\'t really follow any of the usual formulas" for Christmas horror.', source: "Vern's Reviews", author: '' },
    { text: '"A very good cast" with inherent "peppiness."', source: 'GBHBL', author: '' },
    { text: '"I loved the heart and angle of this movie."', source: 'Letterboxd', author: 'Charlie' },
    { text: '"Shockingly well made Christmas comedy of errors horror type jam" with "humor that actually lands!"', source: 'Letterboxd', author: '' },
    { text: '"There is something quite charming hidden beneath this often awkward yet humourous holiday tail."', source: 'Letterboxd', author: 'Gr8_Mutato' },
    { text: '"Surprisingly funny and entertaining. I might give it another watch next year."', source: 'Letterboxd', author: 'John Lally' },
  ],
  imdb: 'https://www.imdb.com/title/tt10047464/',
  letterboxd: 'https://letterboxd.com/film/the-christmas-spirit-2022/',
  appleTV: 'https://tv.apple.com/us/movie/the-christmas-spirit/umc.cmc.79e40iq77wmjpogs8iaiac6e4',
};
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{film.title} — Warehouse Film Distribution</title>
  <meta name="description" content={film.logline}>
  <meta property="og:title" content={film.title}>
  <meta property="og:description" content={film.logline}>
  <meta property="og:image" content={film.poster}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Creepster&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="https://www.whfdistribution.com" class="logo">WHF Distribution</a>
      <div class="nav-links">
        <a href={`${base}/director`}>Director</a>
        <a href="#trailer">Trailer</a>
        <a href="#about">About</a>
        <a href={`${base}/tcs/watch`}>Own It</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-split">
        <div class="hero-left" style={`background-image: url('${base}/images/tcs-spirit-bg.png')`}></div>
        <div class="hero-right" style={`background-image: url('${base}/images/tcs-hero-cole-crop.png')`}></div>
      </div>
      <div class="hero-overlay"></div>
      <div class="xmas-lights">
        <span class="light red"></span><span class="light green"></span><span class="light gold"></span><span class="light blue"></span><span class="light red"></span><span class="light green"></span><span class="light gold"></span><span class="light blue"></span><span class="light red"></span><span class="light green"></span><span class="light gold"></span><span class="light blue"></span><span class="light red"></span><span class="light green"></span><span class="light gold"></span>
      </div>
      <div class="hero-content">
        <p class="hero-meta">
          {film.genres.map(g => <span class="genre-pill">{g}</span>)}
        </p>
        <h1 class="title-main">THE<br/>CHRISTMAS<br/>SPIRIT</h1>
        <p class="hero-tagline">{film.tagline}</p>
        <p class="hero-cast">Starring <strong>{film.starringLine}</strong></p>
        <div class="hero-cta">
          {film.trailer && <a href="#trailer" class="btn-primary">Watch Trailer</a>}
          <a href={`${base}/tcs/watch`} class="btn-ghost">Own It — DRM Free</a>
        </div>
      </div>
    </section>

    <!-- WHAT THEY'RE SAYING -->
    <section class="press">
      <div class="section-inner">
        <h2 class="section-label">What They're Saying</h2>
        <div class="featured-quote">
          <blockquote>{film.pressQuotes[0].text}</blockquote>
          <cite>{film.pressQuotes[0].source}{film.pressQuotes[0].author && ` — ${film.pressQuotes[0].author}`}</cite>
        </div>
        <div class="press-grid">
          {film.pressQuotes.slice(1).map(q => (
            <div class="press-card">
              <blockquote>{q.text}</blockquote>
              <cite><span class="source">{q.source}</span>{q.author && ` — ${q.author}`}</cite>
            </div>
          ))}
        </div>
        <div class="press-links">
          <a href="https://filmthreat.com/reviews/the-christmas-spirit/" target="_blank" rel="noopener">Film Threat Review</a>
          <a href="http://foritismansnumber.blogspot.com/2024/12/shudder-saturday-christmas-spirit-2023.html" target="_blank" rel="noopener">Shudder Saturday Review</a>
          <a href={film.imdb} target="_blank" rel="noopener">IMDb</a>
          <a href={film.letterboxd} target="_blank" rel="noopener">Letterboxd</a>
          <a href={film.appleTV} target="_blank" rel="noopener">Apple TV</a>
        </div>
      </div>
    </section>

    <!-- TRAILER -->
    {film.trailer && (
    <section class="trailer" id="trailer">
      <div class="section-inner">
        <h2 class="section-label">Watch The Trailer</h2>
        <div class="trailer-embed">
          <iframe
            src={film.trailer}
            title={`${film.title} — Trailer`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
    )}

    <!-- STORY -->
    <section class="story" id="about">
      <div class="section-inner story-layout">
        <div class="story-text">
          <h2 class="section-label">The Story</h2>
          <p class="synopsis">{film.synopsis}</p>
          <p class="director-credit">A film by <strong>{film.director}</strong></p>
        </div>
        <div class="story-poster">
          <img src={film.poster} alt={`${film.title} — Official Poster`} width="400" height="514" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    {film.stills.length > 0 && (
    <section class="gallery">
      <div class="section-inner">
        <h2 class="section-label">Gallery</h2>
        <div class="gallery-grid">
          {film.stills.map(s => (
            <div class="gallery-item">
              <img src={s.src} alt={s.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>
    )}

    <!-- CAST & CREW -->
    <section class="cast">
      <div class="section-inner">
        <h2 class="section-label">Cast & Filmmakers</h2>
        <div class="filmmakers">
          {film.filmmakers.map(f => (
            <div class="filmmaker-card">
              <p class="cast-name">{f.name}</p>
              <p class="cast-role">{f.role}</p>
            </div>
          ))}
        </div>
        <div class="cast-divider"></div>
        <div class="cast-grid">
          {film.cast.map(c => (
            <div class="cast-card">
              <p class="cast-name">{c.name}</p>
              {c.role && <p class="cast-role">{c.role}</p>}
              {c.note && <p class="cast-known">{c.note}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHERE TO WATCH -->
    <section class="where">
      <div class="section-inner">
        <h2 class="section-label">Available Now</h2>
        <p class="where-headline">Streaming everywhere December 2024.</p>
        <p class="where-body">Released by <a href="https://www.whfdistribution.com" target="_blank" rel="noopener">Warehouse Film Distribution Inc.</a> in Canada across all major platforms.</p>
        <div class="platform-row">
          <a href={film.appleTV} target="_blank" rel="noopener" class="platform-badge">Apple TV</a>
          <a href={`${base}/tcs/watch`} class="platform-badge">Gumroad (DRM-Free)</a>
        </div>
        <div class="where-cta">
          <a href={`${base}/tcs/watch`} class="btn-primary">Own It — $6.99</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-inner">
        <p class="footer-dist">Distributed by <a href="https://www.whfdistribution.com">Warehouse Film Distribution Inc.</a></p>
        <div class="footer-links">
          <a href={film.imdb} target="_blank" rel="noopener">IMDb</a>
          <a href={film.letterboxd} target="_blank" rel="noopener">Letterboxd</a>
          <a href="mailto:info@whfdistribution.com">Press Inquiries</a>
        </div>
        <p class="copyright">&copy; 2024 Warehouse Film Distribution Inc. All rights reserved.</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Movie",
    "name": film.title,
    "datePublished": "2024",
    "genre": film.genres,
    "director": { "@type": "Person", "name": film.director },
    "actor": film.cast.map(c => ({ "@type": "Person", "name": c.name })),
    "description": film.logline,
    "duration": "PT85M",
    ...(film.trailer ? {
      "trailer": {
        "@type": "VideoObject",
        "name": `${film.title} — Trailer`,
        "embedUrl": film.trailer,
        "thumbnailUrl": "https://vumbnail.com/1025758181.jpg"
      }
    } : {}),
    "productionCompany": {
      "@type": "Organization",
      "name": "Warehouse Film Distribution Inc.",
      "url": "https://www.whfdistribution.com"
    }
  })} />
</body>
</html>

<style>
  /* ===== RESET & BASE ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #0a0806;
    color: #e5e5e5;
    min-height: 100vh;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { color: #c41e3a; text-decoration: none; transition: color 0.2s; }
  a:hover { color: #ff4d6a; }
  img { max-width: 100%; height: auto; }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10, 8, 6, 0.85); backdrop-filter: blur(12px);
    border-bottom: 2px solid #c41e3a;
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 14px 24px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .logo {
    font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 16px;
    letter-spacing: 3px; text-transform: uppercase; color: #fff;
  }
  .logo:hover { color: #c41e3a; }
  .nav-links { display: flex; gap: 24px; }
  .nav-links a {
    font-family: 'Oswald', sans-serif; font-size: 13px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.6);
  }
  .nav-links a:hover { color: #c41e3a; }

  /* ===== HERO ===== */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; background: #0a0806;
  }
  .hero-split {
    position: absolute; inset: 0; display: flex; overflow: hidden;
  }
  .hero-left {
    width: 50%; height: 100%;
    background-size: cover; background-position: center center;
    background-repeat: no-repeat;
    filter: brightness(1.3) contrast(1.1);
  }
  .hero-right {
    width: 50%; height: 100%;
    background-size: cover; background-position: center center;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to bottom,
        rgba(10, 8, 6, 0.0) 0%,
        rgba(10, 8, 6, 0.0) 50%,
        rgba(10, 8, 6, 0.6) 75%,
        rgba(10, 8, 6, 0.95) 90%,
        rgba(10, 8, 6, 1) 100%
      );
  }

  /* ===== CHRISTMAS LIGHTS ===== */
  .xmas-lights {
    position: absolute; top: 0; left: 0; right: 0; z-index: 2;
    display: flex; justify-content: center; gap: 20px; padding: 8px 0;
    overflow: hidden;
  }
  .light {
    width: 10px; height: 14px; border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    animation: glow 2s ease-in-out infinite alternate;
    flex-shrink: 0;
  }
  .light.red { background: #ff1744; box-shadow: 0 0 12px #ff1744, 0 0 24px rgba(255,23,68,0.4); animation-delay: 0s; }
  .light.green { background: #00e676; box-shadow: 0 0 12px #00e676, 0 0 24px rgba(0,230,118,0.4); animation-delay: 0.3s; }
  .light.gold { background: #ffd600; box-shadow: 0 0 12px #ffd600, 0 0 24px rgba(255,214,0,0.4); animation-delay: 0.6s; }
  .light.blue { background: #448aff; box-shadow: 0 0 12px #448aff, 0 0 24px rgba(68,138,255,0.4); animation-delay: 0.9s; }
  @keyframes glow {
    0% { opacity: 0.5; transform: scale(0.9); }
    100% { opacity: 1; transform: scale(1.1); }
  }

  .hero-content {
    position: relative; z-index: 3; text-align: center;
    padding: 80px 24px 0; max-width: 900px;
  }
  .hero-meta {
    display: flex; align-items: center; justify-content: center;
    gap: 10px; margin-bottom: 24px; flex-wrap: wrap;
  }
  .genre-pill {
    padding: 4px 14px; border: 2px solid #c41e3a; border-radius: 3px;
    color: #ff4d6a; font-family: 'Oswald', sans-serif;
    font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
  }
  .title-main {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: 700; line-height: 0.9;
    text-transform: uppercase; color: #fff;
    margin-bottom: 24px;
    text-shadow: 0 0 40px rgba(196, 30, 58, 0.4), 0 4px 0 rgba(0,0,0,0.3);
  }
  .hero-tagline {
    font-size: clamp(1rem, 2.2vw, 1.3rem);
    color: rgba(255,255,255,0.8); font-weight: 300;
    margin-bottom: 12px; max-width: 650px;
    margin-left: auto; margin-right: auto;
    line-height: 1.5;
  }
  .hero-cast {
    font-family: 'Oswald', sans-serif;
    font-size: 15px; color: rgba(255,255,255,0.4);
    letter-spacing: 2px; text-transform: uppercase; margin-bottom: 36px;
  }
  .hero-cast strong { color: rgba(255,255,255,0.7); }
  .hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* ===== BUTTONS ===== */
  .btn-primary {
    display: inline-block; padding: 16px 40px;
    background: #c41e3a; color: #fff;
    font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    border: 2px solid #c41e3a; transition: all 0.25s ease;
  }
  .btn-primary:hover { background: #ff1744; border-color: #ff1744; color: #fff; box-shadow: 0 0 20px rgba(255,23,68,0.4); }
  .btn-ghost {
    display: inline-block; padding: 16px 40px;
    border: 2px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.7);
    font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase; transition: all 0.25s ease;
  }
  .btn-ghost:hover { border-color: #00e676; color: #00e676; }
  .btn-sm { padding: 10px 24px; font-size: 12px; }

  /* ===== SECTIONS ===== */
  .section-inner { max-width: 1100px; margin: 0 auto; padding: 80px 24px; }
  .section-label {
    font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600;
    letter-spacing: 5px; text-transform: uppercase;
    color: #c41e3a; margin-bottom: 40px; text-align: center;
  }

  /* ===== PRESS ===== */
  .press {
    border-top: 3px solid #c41e3a;
    background: linear-gradient(180deg, #120808 0%, #0a0806 100%);
  }
  .featured-quote {
    text-align: center; margin-bottom: 48px; padding: 0 24px;
  }
  .featured-quote blockquote {
    font-family: 'Creepster', cursive; font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: #ffd600; line-height: 1.4; margin-bottom: 16px;
  }
  .featured-quote cite {
    font-family: 'Oswald', sans-serif; font-size: 14px; font-style: normal;
    color: #888; letter-spacing: 2px; text-transform: uppercase;
  }
  .press-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px; margin-bottom: 32px;
  }
  .press-card {
    padding: 28px; background: rgba(196, 30, 58, 0.06);
    border: 1px solid rgba(196, 30, 58, 0.15);
  }
  .press-card blockquote {
    font-size: 15px; color: #ccc; font-style: italic;
    font-weight: 300; line-height: 1.7; margin-bottom: 12px;
  }
  .press-card cite {
    font-size: 11px; font-style: normal; color: #666; letter-spacing: 0.5px;
  }
  .press-card .source {
    color: #c41e3a; font-family: 'Oswald', sans-serif;
    font-weight: 600; text-transform: uppercase; letter-spacing: 2px; font-size: 10px;
  }
  .press-links {
    display: flex; gap: 24px; justify-content: center;
    padding-top: 24px; border-top: 1px solid rgba(196, 30, 58, 0.15);
  }
  .press-links a {
    font-family: 'Oswald', sans-serif; font-size: 13px;
    letter-spacing: 2px; text-transform: uppercase;
    color: #555; font-weight: 500;
  }
  .press-links a:hover { color: #c41e3a; }

  /* ===== TRAILER ===== */
  .trailer { border-top: 1px solid rgba(196, 30, 58, 0.2); }
  .trailer-embed {
    position: relative; padding-bottom: 56.25%; height: 0;
    background: #000; max-width: 900px; margin: 0 auto;
    border: 2px solid rgba(196, 30, 58, 0.3);
  }
  .trailer-embed iframe {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;
  }

  /* ===== STORY ===== */
  .story { border-top: 1px solid rgba(196, 30, 58, 0.2); }
  .story-layout { display: flex; gap: 64px; align-items: flex-start; }
  .story-text { flex: 1; }
  .synopsis { font-size: 17px; color: #bbb; line-height: 1.8; max-width: 600px; margin-bottom: 32px; }
  .director-credit {
    font-family: 'Oswald', sans-serif; font-size: 15px;
    color: #666; letter-spacing: 1px; text-transform: uppercase;
  }
  .director-credit strong { color: #c41e3a; }
  .story-poster { flex-shrink: 0; }
  .story-poster img { width: 300px; height: auto; box-shadow: 0 16px 48px rgba(196, 30, 58, 0.2), 0 0 80px rgba(196, 30, 58, 0.1); border: 2px solid rgba(196, 30, 58, 0.2); }

  /* ===== GALLERY ===== */
  .gallery {
    border-top: 1px solid rgba(196, 30, 58, 0.2);
    background: #0d0908;
  }
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; }
  .gallery-item { overflow: hidden; aspect-ratio: 16/9; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .gallery-item:hover img { transform: scale(1.05); }

  /* ===== CAST ===== */
  .cast { border-top: 1px solid rgba(196, 30, 58, 0.2); }
  .cast-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 28px; }
  .cast-name {
    font-family: 'Oswald', sans-serif; font-size: 16px;
    font-weight: 600; color: #e5e5e5; margin-bottom: 2px;
  }
